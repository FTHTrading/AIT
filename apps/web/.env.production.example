# AIT Biofield OS - production-safe launch template
# Use placeholders only. Never commit real credentials.

DATABASE_URL=postgresql://user:pass@host:5432/biofield_ait
AIT_STORAGE_BACKEND=file

AIT_SESSION_SECRET=replace-with-strong-random-secret
AIT_ADMIN_USERS_JSON=[{"username":"admin","password":"change-me","role":"ADMIN","displayName":"Site Admin"}]

# OIDC (configure one path: JWKS or shared secret)
AIT_OIDC_JWKS_URL=https://your-issuer.example.com/.well-known/jwks.json
AIT_OIDC_SECRET=replace-if-using-hs256
AIT_OIDC_ISSUER=https://your-issuer.example.com
AIT_OIDC_AUDIENCE=biofield-ait
AIT_OIDC_ROLE_CLAIM=ait_role

# Storage and chain adapters (leave unset unless intentionally enabled)
PINATA_JWT=
WEB3_STORAGE_TOKEN=
AIT_CHAIN_SIGNER_PRIVATE_KEY=
APOSTLE_URL=http://localhost:7332
AIT_X402_DEV_PROOF=false

# Safe-launch adapter flags
AIT_IPFS_UPLOAD_ENABLED=false
AIT_POLYGON_BROADCAST_ENABLED=false
AIT_XRPL_BROADCAST_ENABLED=false
AIT_UNYKORN_BROADCAST_ENABLED=false

# Backward-compatible runtime flags used by current routes
ENABLE_POLYGON_BROADCAST=false
ENABLE_XRPL_BROADCAST=false
ENABLE_UNYKORN_BROADCAST=false

# Voice defaults
AIT_VOICE_ENABLED=true
AIT_VOICE_PROVIDER=browser
AIT_VOICE_EXTERNAL_ENABLED=false
AIT_VOICE_ALLOW_ADMIN=false
